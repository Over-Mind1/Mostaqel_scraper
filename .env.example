# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-EXAMPLE-TOKEN

# Target chat id (user, group, or channel)
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# Optional custom projects URL (default is Mostaqel open projects)
MOSTAQL_URL=https://mostaql.com/projects

# Polling interval in seconds
POLL_INTERVAL=120
